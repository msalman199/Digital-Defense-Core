Subtask 3.3: Creating a Policy Enforcement Script
Create a script that enforces security policies:

nano ~/defense-lab/enforce-policies.sh
Add the following script content:

#!/bin/bash

# Security Policy Enforcement Script
# Enforces basic security policies on the system

echo "=== SECURITY POLICY ENFORCEMENT ==="
echo "Starting policy enforcement at $(date)"

# Ensure proper permissions on security directories
echo "Enforcing directory permissions..."
sudo chown root:security-admins /opt/security/admin
sudo chmod 750 /opt/security/admin

sudo chown root:security-analysts /opt/security/analyst
sudo chmod 750 /opt/security/analyst

sudo chown root:security-users /opt/security/shared
sudo chmod 755 /opt/security/shared

sudo chown root:security-admins /opt/security/logs
sudo chmod 740 /opt/security/logs

# Set secure permissions on critical system files
echo "Securing critical system files..."
sudo chmod 644 /etc/passwd
sudo chmod 640 /etc/shadow
sudo chmod 440 /etc/sudoers

# Enable firewall if not already enabled
echo "Checking firewall status..."
if ! sudo ufw status | grep -q "Status: active"; then
    echo "Enabling UFW firewall..."
    sudo ufw --force enable
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    sudo ufw allow ssh
fi

# Check for users with empty passwords
echo "Checking for users with empty passwords..."
EMPTY_PASS_USERS=$(sudo awk -F: '($2 == "") {print $1}' /etc/shadow)
if [ ! -z "$EMPTY_PASS_USERS" ]; then
    echo "WARNING: Users with empty passwords found: $EMPTY_PASS_USERS"
    echo "$(date): Users with empty passwords: $EMPTY_PASS_USERS" | sudo tee -a /opt/security/logs/policy-violations.log
fi

# Log policy enforcement
echo "$(date): Security policies enforced" | sudo tee -a /opt/security/logs/policy-enforcement.log

echo "Policy enforcement completed successfully"
Make the script executable:

chmod +x ~/defense-lab/enforce-policies.sh

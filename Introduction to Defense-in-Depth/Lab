Subtask 3.5: Creating a Master Security Script
Create a comprehensive script that combines all security functions:

nano ~/defense-lab/security-manager.sh
Add the following script content:

#!/bin/bash

# Master Security Management Script
# Provides a menu-driven interface for security operations

show_menu() {
    echo ""
    echo "=== DEFENSE-IN-DEPTH SECURITY MANAGER ==="
    echo "1. Create Security User"
    echo "2. Run Security Audit"
    echo "3. Enforce Security Policies"
    echo "4. View Security Logs"
    echo "5. Test RBAC Access"
    echo "6. Exit"
    echo ""
    read -p "Select an option (1-6): " choice
}

create_user() {
    echo ""
    read -p "Enter username: " username
    echo "Available roles: admin, analyst, user"
    read -p "Enter role: " role
    ./create-security-user.sh $username $role
}

view_logs() {
    echo ""
    echo "Available log files:"
    sudo ls -la /opt/security/logs/
    echo ""
    read -p "Enter log filename to view (or press Enter to skip): " logfile
    if [ ! -z "$logfile" ]; then
        sudo cat /opt/security/logs/$logfile
    fi
}

test_rbac() {
    echo ""
    echo "RBAC Test Results:"
    echo "Security Admin Directory:"
    ls -la /opt/security/admin/ 2>/dev/null || echo "Access denied (as expected for non-admin users)"
    echo ""
    echo "Security Analyst Directory:"
    ls -la /opt/security/analyst/ 2>/dev/null || echo "Access denied (as expected for non-analyst users)"
    echo ""
    echo "Shared Directory:"
    ls -la /opt/security/shared/
}

while true; do
    show_menu
    case $choice in
        1)
            create_user
            ;;
        2)
            ./security-audit.sh
            ;;
        3)
            ./enforce-policies.sh
            ;;
        4)
            view_logs
            ;;
        5)
            test_rbac
            ;;
        6)
            echo "Exiting Security Manager"
            exit 0
            ;;
        *)
            echo "Invalid option. Please select 1-6."
            ;;
    esac
    read -p "Press Enter to continue..."
done

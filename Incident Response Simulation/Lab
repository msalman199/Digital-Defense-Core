Task 6: Cleanup and System Restoration
Subtask 6.1: Terminate Suspicious Processes
Clean up the simulated suspicious processes safely.

# Create cleanup script
cat > cleanup_simulation.sh << 'EOF'
#!/bin/bash

echo "=== CLEANING UP SIMULATION ENVIRONMENT ==="

# Stop suspicious processes
if [ -f server_pid.txt ]; then
    SUSPICIOUS_PID=$(cat server_pid.txt | grep -o '[0-9]*')
    if [ ! -z "$SUSPICIOUS_PID" ]; then
        echo "Terminating suspicious server (PID: $SUSPICIOUS_PID)..."
        kill $SUSPICIOUS_PID 2>/dev/null || echo "Process already terminated"
    fi
fi

if [ -f nc_pid.txt ]; then
    NC_PID=$(cat nc_pid.txt)
    if [ ! -z "$NC_PID" ]; then
        echo "Terminating netcat listener (PID: $NC_PID)..."
        kill $NC_PID 2>/dev/null || echo "Process already terminated"
    fi
fi

# Clean up any remaining suspicious processes
pkill -f "suspicious_server.py" 2>/dev/null || echo "No suspicious server processes found"
pkill -f "nc.*9999" 2>/dev/null || echo "No netcat processes found"

echo "Process cleanup completed"
EOF


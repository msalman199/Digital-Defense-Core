Step 2.2: Create Test VM
Create a minimal VM for testing security configurations:

# Create VM disk image
sudo qemu-img create -f qcow2 /var/lib/libvirt/images/test-vm.qcow2 5G

# Create basic VM definition
cat > ~/vm-security/test-vm.xml << 'EOF'
<domain type='kvm'>
  <name>test-vm</name>
  <memory unit='KiB'>1048576</memory>
  <vcpu placement='static'>1</vcpu>
  <os>
    <type arch='x86_64' machine='pc'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <cpu mode='host-model'/>
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/test-vm.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='secure-net'/>
      <model type='virtio'/>
    </interface>
    <graphics type='vnc' port='-1' autoport='yes' listen='127.0.0.1'/>
  </devices>
</domain>
EOF

# Define the VM
sudo virsh define ~/vm-security/test-vm.xml

# Verify VM creation
virsh list --all

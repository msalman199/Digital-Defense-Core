Subtask 4.2: Vulnerability Response Workflow
Create a vulnerability response script:
cat > vulnerability-response.sh << 'EOF'
#!/bin/bash

CONTAINER_NAME=$1
SEVERITY_THRESHOLD="HIGH"

if [ -z "$CONTAINER_NAME" ]; then
    echo "Usage: $0 <container_name>"
    exit 1
fi

echo "=== Container Security Response Workflow ==="
echo "Target Container: $CONTAINER_NAME"

# Get container image
IMAGE=$(docker inspect $CONTAINER_NAME --format='{{.Config.Image}}')
echo "Image: $IMAGE"

# Scan for vulnerabilities
echo "Scanning for vulnerabilities..."
trivy image --severity $SEVERITY_THRESHOLD --format json --output vuln-report.json $IMAGE

# Count vulnerabilities
HIGH_COUNT=$(cat vuln-report.json | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="HIGH")] | length')
CRITICAL_COUNT=$(cat vuln-report.json | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity=="CRITICAL")] | length')

echo "High severity vulnerabilities: $HIGH_COUNT"
echo "Critical vulnerabilities: $CRITICAL_COUNT"

# Response actions
if [ "$CRITICAL_COUNT" -gt 0 ]; then
    echo "CRITICAL: Stopping container due to critical vulnerabilities"
    docker stop $CONTAINER_NAME
    echo "Container stopped. Manual intervention required."
elif [ "$HIGH_COUNT" -gt 10 ]; then
    echo "WARNING: High number of vulnerabilities detected"
    echo "Consider updating the base image"
else
    echo "PASS: Container security within acceptable limits"
fi

# Generate summary report
echo "=== Security Summary ===" > security-summary.txt
echo "Container: $CONTAINER_NAME" >> security-summary.txt
echo "Image: $IMAGE" >> security-summary.txt
echo "Scan Date: $(date)" >> security-summary.txt
echo "Critical Vulnerabilities: $CRITICAL_COUNT" >> security-summary.txt
echo "High Vulnerabilities: $HIGH_COUNT" >> security-summary.txt

cat security-summary.txt
EOF

chmod +x vulnerability-response.sh
Test the response workflow:
./vulnerability-response.sh secure-nginx

#!/bin/bash

# Automated Network Architecture Setup Script
# This script creates a complete secure network architecture

set -e  # Exit on any error

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to check if running as root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This script must be run as root or with sudo"
        exit 1
    fi
}

# Function to backup current iptables rules
backup_iptables() {
    print_status "Backing up current iptables rules..."
    iptables-save > /tmp/iptables_backup_$(date +%Y%m%d_%H%M%S).rules
    print_status "Backup saved to /tmp/"
}

# Function to create virtual network interfaces
create_interfaces() {
    print_status "Creating virtual network interfaces..."
    
    # Remove existing interfaces if they exist
    ip link delete dmz0 2>/dev/null || true
    ip link delete internal0 2>/dev/null || true
    ip link delete mgmt0 2>/dev/null || true
    
    # Create DMZ interface
    ip link add name dmz0 type dummy
    ip addr add 192.168.10.1/24 dev dmz0
    ip link set dmz0 up
    
    # Create Internal interface
    ip link add name internal0 type dummy
    ip addr add 192.168.20.1/24 dev internal0
    ip link set internal0 up
    
    # Create Management interface
    ip link add name mgmt0 type dummy
    ip addr add 192.168.30.1/24 dev mgmt0
    ip link set mgmt0 up
    
    print_status "Virtual interfaces created successfully"
}

# Function to enable IP forwarding
enable_forwarding() {
    print_status "Enabling IP forwarding..."
    sysctl net.ipv4.ip_forward=1
    
    # Make permanent
    if ! grep -q "net.ipv4.ip_forward=1" /etc/sysctl.conf; then
        echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf
    fi
}

# Function to configure iptables rules
configure_iptables() {
    print_status "Configuring iptables rules..."
    
    # Flush existing rules
    iptables -F
    iptables -X
    iptables -t nat -F
    iptables -t nat -X
    
    # Set default policies
    iptables -P INPUT DROP
    iptables -P FORWARD DROP
    iptables -P OUTPUT ACCEPT
    
    # Define networks
    DMZ_NET="192.168.10.0/24"
    INTERNAL_NET="192.168.20.0/24"
    MGMT_NET="192.168.30.0/24"
    
    # Allow loopback
    iptables -A INPUT -i lo -j ACCEPT
    
    # Allow established connections
    iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
    iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT
    
    # Allow SSH to this machine from management network
    iptables -A INPUT -s $MGMT_NET -p tcp --dport 22 -j ACCEPT
    
    # DMZ access rules
    iptables -A FORWARD -d $DMZ_NET -p tcp --dport 80 -j ACCEPT
    iptables -A FORWARD -d $DMZ_NET -p tcp --dport 443 -j ACCEPT
    iptables -A FORWARD -s $MGMT_NET -d $DMZ_NET -p tcp --dport 22 -j ACCEPT
    
    # Internal network rules
    iptables -A FORWARD -s $INTERNAL_NET -d $DMZ_NET -p tcp -m multiport --dports 80,443 -j ACCEPT
    iptables -A FORWARD -s $DMZ_NET -d $INTERNAL_NET -j DROP
    
    # Management network rules
    iptables -A FORWARD -s $MGMT_NET -j ACCEPT
    iptables -A FORWARD -d $MGMT_NET ! -s $MGMT_NET -j DROP
    
    # Logging
    iptables -A INPUT -j LOG --log-prefix "INPUT_DROP: " --log-level 4
    iptables -A FORWARD -j LOG --log-prefix "FORWARD_DROP: " --log-level 4
    
    print_status "iptables rules configured successfully"
}

# Function to create monitoring script
create_monitoring() {
    print_status "Creating network monitoring script..."
    
    cat > /usr/local/bin/network_monitor.sh << 'EOF'
#!/bin/bash

# Network Monitoring Script

echo "=== Network Architecture Status ==="
echo "Date: $(date)"
echo

echo "=== Virtual Interfaces ==="
ip addr show | grep -E "(dmz0|internal0|mgmt0)" -A 2

echo
echo "=== iptables Rules Summary ==="
echo "INPUT rules:"
iptables -L INPUT -n --line-numbers | head -10

echo
echo "FORWARD rules:"
iptables -L FORWARD -n --line-numbers | head -15

echo
echo "=== Recent Dropped Packets ==="
tail -20 /var/log/kern.log | grep -E "(INPUT_DROP|FORWARD_DROP)" | tail -5

echo
echo "=== Network Connections ==="
netstat -tuln | head -10
EOF

    chmod +x /usr/local/bin/network_monitor.sh
    print_status "Monitoring script created at /usr/local/bin/network_monitor.sh"
}

# Function to create cleanup script
create_cleanup() {
    print_status "Creating cleanup script..."
    
    cat > /usr/local/bin/network_cleanup.sh << 'EOF'
#!/bin/bash

# Network Cleanup Script

echo "Cleaning up network configuration..."

# Remove virtual interfaces
ip link delete dmz0 2>/dev/null || true
ip link delete internal0 2>/dev/null || true
ip link delete mgmt0 2>/dev/null || true

# Flush iptables rules
iptables -F
iptables -X
iptables -t nat -F
iptables -t nat -X

# Reset default policies
iptables -P INPUT ACCEPT
iptables -P FORWARD ACCEPT
iptables -P OUTPUT ACCEPT

echo "Network configuration cleaned up successfully"
EOF

    chmod +x /usr/local/bin/network_cleanup.sh
    print_status "Cleanup script created at /usr/local/bin/network_cleanup.sh"
}

# Main execution
main() {
    print_status "Starting Automated Network Architecture Setup"
    
    check_root
    backup_iptables
    create_interfaces
    enable_forwarding
    configure_iptables
    create_monitoring
    create_cleanup
    
    print_status "Network architecture setup completed successfully!"
    print_status "Use '/usr/local/bin/network_monitor.sh' to check status"
    print_status "Use '/usr/local/bin/network_cleanup.sh' to remove configuration"
}

# Run main function
main "$@"

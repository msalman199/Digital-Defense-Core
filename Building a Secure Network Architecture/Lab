#!/bin/bash

# Network Validation Script
# Tests network segmentation rules

# Color codes
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_test() {
    echo -e "${YELLOW}[TEST]${NC} $1"
}

print_pass() {
    echo -e "${GREEN}[PASS]${NC} $1"
}

print_fail() {
    echo -e "${RED}[FAIL]${NC} $1"
}

# Test 1: Check if virtual interfaces exist
test_interfaces() {
    print_test "Checking virtual network interfaces..."
    
    if ip addr show dmz0 &>/dev/null && ip addr show internal0 &>/dev/null && ip addr show mgmt0 &>/dev/null; then
        print_pass "All virtual interfaces are present"
        return 0
    else
        print_fail "Some virtual interfaces are missing"
        return 1
    fi
}

# Test 2: Check IP forwarding
test_forwarding() {
    print_test "Checking IP forwarding..."
    
    if [[ $(cat /proc/sys/net/ipv4/ip_forward) == "1" ]]; then
        print_pass "IP forwarding is enabled"
        return 0
    else
        print_fail "IP forwarding is disabled"
        return 1
    fi
}

# Test 3: Check iptables rules
test_iptables() {
    print_test "Checking iptables rules..."
    
    local rules_count=$(sudo iptables -L FORWARD -n | wc -l)
    if [[ $rules_count -gt 5 ]]; then
        print_pass "iptables rules are configured"
        return 0
    else
        print_fail "iptables rules appear to be missing"
        return 1
    fi
}

# Test 4: Check for specific segmentation rules
test_segmentation_rules() {
    print_test "Checking network segmentation rules..."
    
    local dmz_rules=$(sudo iptables -L FORWARD -n | grep -c "192.168.10.0/24")
    local internal_rules=$(sudo iptables -L FORWARD -n | grep -c "192.168.20.0/24")
    local mgmt_rules=$(sudo iptables -L FORWARD -n | grep -c "192.168.30.0/24")
    
    if [[ $dmz_rules -gt 0 && $internal_rules -gt 0 && $mgmt_rules -gt 0 ]]; then
        print_pass "Network segmentation rules are present"
        return 0
    else
        print_fail "Network segmentation rules are incomplete"
        return 1
    fi
}

# Test 5: Check logging configuration
test_logging() {
    print_test "Checking logging configuration..."
    
    if sudo iptables -L -n | grep -q "LOG"; then
        print_pass "Logging rules are configured"
        return 0
    else
        print_fail "Logging rules are missing"
        return 1
    fi
}

# Main validation function
main() {
    echo "=== Network Architecture Validation ==="
    echo "Date: $(date)"
    echo
    
    local total_tests=0
    local passed_tests=0
    
    # Run all tests
    tests=(
        "test_interfaces"
        "test_forwarding"
        "test_iptables"
        "test_segmentation_rules"
        "test_logging"
    )
    
    for test in "${tests[@]}"; do
        ((total_tests++))
        if $test; then
            ((passed_tests++))
        fi
        echo
    done
    
    echo "=== Validation Summary ==="
    echo "Tests passed: $passed_tests/$total_tests"
    
    if [[ $passed_tests -eq $total_tests ]]; then
        print_pass "All tests passed! Network architecture is properly configured."
        exit 0
    else
        print_fail "Some tests failed. Please review the configuration."
        exit 1
    fi
}

# Check if running as root
if [[ $EUID -ne 0 ]]; then
    echo "This script requires sudo privileges for some tests"
    echo "Run with: sudo $0"
    exit 1
fi

main "$@"

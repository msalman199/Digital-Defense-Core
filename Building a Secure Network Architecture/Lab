#!/bin/bash

# Network Security Dashboard

# Function to display header
show_header() {
    clear
    echo "=================================================="
    echo "    SECURE NETWORK ARCHITECTURE DASHBOARD"
    echo "=================================================="
    echo "Last updated: $(date)"
    echo
}

# Function to show interface status
show_interfaces() {
    echo "=== NETWORK INTERFACES ==="
    printf "%-12s %-15s %-10s\n" "Interface" "IP Address" "Status"
    echo "----------------------------------------"
    
    for iface in dmz0 internal0 mgmt0; do
        if ip addr show $iface &>/dev/null; then
            local ip=$(ip addr show $iface | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1)
            local status=$(ip link show $iface | grep -o 'state [A-Z]*' | cut -d' ' -f2)
            printf "%-12s %-15s %-10s\n" "$iface" "$ip" "$status"
        else
            printf "%-12s %-15s %-10s\n" "$iface" "N/A" "DOWN"
        fi
    done
    echo
}

# Function to show firewall status
show_firewall() {
    echo "=== FIREWALL STATUS ==="
    local input_rules=$(sudo iptables -L INPUT -n | grep -c "^ACCEPT\|^DROP\|^REJECT")
    local forward_rules=$(sudo iptables -L FORWARD -n | grep -c "^ACCEPT\|^DROP\|^REJECT")
    local output_rules=$(sudo iptables -L OUTPUT -n | grep -c "^ACCEPT\|^DROP\|^REJECT")
    
    echo "INPUT rules: $input_rules"
    echo "FORWARD rules: $forward_rules"
    echo "OUTPUT rules: $output_rules"
    echo
}

# Function to show recent activity
show_activity() {
    echo "=== RECENT SECURITY EVENTS ==="
    if [[ -f /var/log/kern.log ]]; then
        sudo tail -10 /var/log/kern.log | grep -E "(DROP|REJECT)" | tail -5 | while read line; do
            echo "$(echo $line | cut -d' ' -f1-3): $(echo $line | grep -o 'SRC=[0-9.]*' | cut -d'=' -f2) -> $(echo $line | grep -o 'DST=[0-9.]*' | cut -d'=' -f2)"
        done
    else
        echo "No recent events found"
    fi
    echo
}

# Function to show network statistics
show_statistics() {
    echo "=== NETWORK STATISTICS ==="
    echo "Active connections: $(netstat -an | grep ESTABLISHED | wc -l)"
    echo "Listening services: $(netstat -tln | grep LISTEN | wc -l)"
    echo "IP forwarding: $(cat /proc/sys/net/ipv4/ip_forward)"
    echo
}

# Main dashboard function
main() {
    while true; do
        show_header
        show_interfaces
        show_firewall
        show_activity
        show_statistics
        
        echo "Press Ctrl+C to exit, or wait 30 seconds for refresh..."
        sleep 30
    done
}

# Check for root privileges
if [[ $EUID -ne 0 ]]; then
    echo "This dashboard requires sudo privileges"
    echo "Run with: sudo $0"
    exit 1
fi

main
